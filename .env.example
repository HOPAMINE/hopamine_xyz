# Convex — https://docs.convex.dev/auth/clerk
# From `npx convex dev` / Convex dashboard deployment settings
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Clerk — https://clerk.com/docs/integrations/convex
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Frontend API issuer URL (JWT "iss"); also set CLERK_DOMAIN on the Convex deployment
CLERK_DOMAIN=
